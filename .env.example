# OTA 地址（--ota-url 参数可覆盖）
DEFAULT_OTA_URL=https://ota.zectrix.com/xiaozhi/ota/

# 预设WiFi（编译时注入，避免每次刷机重新配网）
DEFAULT_WIFI_SSID=
DEFAULT_WIFI_PASSWORD=

# InfluxDB (docker-compose.influxdb.yml)
INFLUXDB_PORT=8086
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminadminadmin
INFLUXDB_ORG=toinc_F1
INFLUXDB_BUCKET=openf1
INFLUXDB_RETENTION=30d
INFLUXDB_TOKEN=changeme

# OpenF1
OPENF1_API_BASE=https://api.openf1.org
